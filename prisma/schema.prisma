// =============================================================================
// SpreeTrail — schema.prisma
// Generated from: AI_CONTEXT.md (Round 1 confirmed + Round 2 assumptions)
// ORM: Prisma
// Database: PostgreSQL
// =============================================================================
//
// ASSUMPTIONS (pending interview Round 2 confirmation):
//   [A1] Authentication: email + password only (no social login). JWT-based sessions.
//   [A2] Group roles: two roles — ADMIN (creator) and MEMBER. Only ADMIN can remove
//        members or delete the group.
//   [A3] Payer: exactly one payer per expense (single person paid the bill).
//   [A4] All four split types are supported: EQUAL, UNEQUAL, PERCENTAGE, SHARES.
//   [A5] Equal split: divided only among selected participants, not all group members.
//   [A6] Settlements: manually recorded by any group member. Directly reduces balance.
//        No "settlement expense" pattern.
//   [A7] Currency: User can select currency per expense. Stored as string.
//        No conversion logic. Default: "INR".
//   [A8] Soft-delete pattern not used for MVP. Hard deletes only.
//   [A9] Comment editing not supported for MVP. Create only.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUM DEFINITIONS
// =============================================================================

/// The type of split applied to an expense.
enum SplitType {
  EQUAL       // Divide total equally among selected participants
  UNEQUAL     // Each participant has an explicit amount assigned
  PERCENTAGE  // Each participant has a percentage that sums to 100
  SHARES      // Each participant has a weight (shares); amount prorated
}

/// Role of a user within a group.
enum GroupRole {
  ADMIN   // Created the group; can manage members and delete group
  MEMBER  // Regular participant
}

// =============================================================================
// TABLE: User
// Purpose: Stores registered users. Credentials are email + hashed password.
//          Avatar is optional. All other entities reference this table.
// =============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   // bcrypt hash — never store plaintext
  avatarUrl    String?  // Optional profile picture URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  groupMemberships  GroupMember[]
  groupsCreated     Group[]            @relation("GroupCreator")
  expensesPaid      Expense[]          @relation("ExpensePayer")
  expensesCreated   Expense[]          @relation("ExpenseCreator")
  expenseParticipations ExpenseParticipant[]
  settlementsPaid   Settlement[]       @relation("SettlementPayer")
  settlementsReceived Settlement[]     @relation("SettlementReceiver")
  comments          ExpenseComment[]

  @@map("users")
}

// =============================================================================
// TABLE: Group
// Purpose: A named collection of users who share expenses.
//          Created by one user (ADMIN). Stores metadata only — no balances.
//          Balances are computed from Expense + Settlement records.
// =============================================================================

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?  // Optional group description (e.g., "Goa Trip 2025")
  createdById String   // FK: the user who created this group → auto ADMIN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdBy   User          @relation("GroupCreator", fields: [createdById], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@map("groups")
}

// =============================================================================
// TABLE: GroupMember
// Purpose: Junction table linking Users to Groups with a role.
//          Enforces uniqueness: one user can only be in a group once.
//          [A2] ADMIN role is assigned to the group creator on group creation.
// =============================================================================

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only appear once per group
  @@unique([groupId, userId])
  @@map("group_members")
}

// =============================================================================
// TABLE: Expense
// Purpose: A single shared expense paid by one member (paidById).
//          Records the total amount, split type, and metadata.
//          The actual per-person breakdown lives in ExpenseParticipant.
//          [A3] Single payer only.
//          [A7] Currency stored as string, default "INR".
// =============================================================================

model Expense {
  id          String    @id @default(uuid())
  groupId     String
  paidById    String    // FK: who paid the full amount upfront
  createdById String    // FK: who added this expense record (may differ from payer)
  description String
  amount      Decimal   @db.Decimal(12, 2) // Total bill amount
  currency    String    @default("INR")    // [A7] User can select currency, no conversion
  splitType   SplitType
  date        DateTime  @default(now())   // Date of the expense (user-selectable)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  group        Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User                @relation("ExpensePayer", fields: [paidById], references: [id])
  createdBy    User                @relation("ExpenseCreator", fields: [createdById], references: [id])
  participants ExpenseParticipant[]
  comments     ExpenseComment[]

  @@map("expenses")
}

// =============================================================================
// TABLE: ExpenseParticipant
// Purpose: Records how much each user owes for a specific expense.
//          One row per (expense, user) pair.
//          All three split helper columns (shareAmount, sharePercentage, shareUnits)
//          are stored; the applicable column depends on Expense.splitType.
//          shareAmount is ALWAYS populated (computed at write time) so balance
//          queries never need to re-derive the split math.
//
//          Split type column usage:
//            EQUAL       → shareAmount only (amount / N)
//            UNEQUAL     → shareAmount (explicitly entered)
//            PERCENTAGE  → sharePercentage + shareAmount (derived)
//            SHARES      → shareUnits + shareAmount (derived)
// =============================================================================

model ExpenseParticipant {
  id               String  @id @default(uuid())
  expenseId        String
  userId           String
  shareAmount      Decimal @db.Decimal(12, 2) // Always populated — the owed amount
  sharePercentage  Decimal? @db.Decimal(5, 2) // Populated for PERCENTAGE split
  shareUnits       Int?                        // Populated for SHARES split

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only appear once per expense
  @@unique([expenseId, userId])
  @@map("expense_participants")
}

// =============================================================================
// TABLE: Settlement
// Purpose: Records a manual payment between two group members.
//          payerId paid receiverId a given amount.
//          [A6] This directly reduces the outstanding balance between the two users.
//          Settlements are NOT expenses — they don't appear in expense lists.
//          They are recorded and factored into balance calculation.
// =============================================================================

model Settlement {
  id         String   @id @default(uuid())
  groupId    String
  payerId    String   // FK: user who paid (the debtor settling up)
  receiverId String   // FK: user who received the payment (the creditor)
  amount     Decimal  @db.Decimal(12, 2)
  note       String?  // Optional memo (e.g., "Paid via UPI")
  settledAt  DateTime @default(now()) // Date the payment happened
  createdAt  DateTime @default(now())

  // Relations
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])

  @@map("settlements")
}

// =============================================================================
// TABLE: ExpenseComment
// Purpose: Threaded comments on a specific expense.
//          [A9] No editing — insert only for MVP.
//          Supports simple text messages; no attachments.
// =============================================================================

model ExpenseComment {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expense_comments")
}
